{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 120,
  "tabWidth": 2,
  "sortPackageJson": true,
  "objectWrap": "collapse",
  "sortImports": {
    "groups": [
      ["^react$", "^elysia$"],
      ["^@/"],
      ["^\\.\\./"],
      ["^\\./"]
    ]
  },
  "ignorePatterns": ["**/*.lock", ".agents/**"]
}
