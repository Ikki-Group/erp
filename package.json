{
  "name": "ikki-erp",
  "version": "1.0.0",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "oxfmt": "^0.42.0",
      "oxlint": "^1.57.0",
      "oxlint-tsgolint": "^0.17.3",
      "typescript": "^6.0.2",
      "zod": "^4.3.6"
    }
  },
  "scripts": {
    "dev:server": "bun --filter @ikki/server dev",
    "dev:web": "bun --filter @ikki/web dev",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "check": "bun run lint && bun run format:check"
  },
  "devDependencies": {
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.17.3",
    "typescript": "^6.0.2"
  }
}
